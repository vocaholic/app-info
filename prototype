<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Spanish Listening & Dictation Master</title>
    <style>
        :root {
            --primary: #e63946;
            --secondary: #457b9d;
            --background: #f8f9fa;
            --card-bg: #ffffff;
            --text: #1d3557;
            --success: #2a9d8f;
            --error: #e76f51;
            --neutral: #6c757d;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--background);
            color: var(--text);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 550px;
            text-align: center;
        }

        .phase-indicator {
            font-weight: bold;
            font-size: 1.2rem;
            color: var(--secondary);
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .progress-bar {
            width: 100%;
            height: 6px;
            background-color: #e0e0e0;
            border-radius: 3px;
            margin-bottom: 20px;
            overflow: hidden;
            position: relative;
        }

        .progress {
            height: 100%;
            background-color: var(--secondary);
            width: 0%;
            transition: width 0.3s ease;
        }

        /* Countdown Timer Strip */
        .timer-bar {
            width: 100%;
            height: 4px;
            background-color: #dee2e6;
            margin-bottom: 15px;
            border-radius: 2px;
            overflow: hidden;
            display: none;
        }

        .timer-fill {
            height: 100%;
            background-color: var(--primary);
            width: 100%;
        }

        .card {
            background-color: var(--card-bg);
            border-radius: 16px;
            padding: 40px 30px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            margin-bottom: 24px;
        }

        .audio-container {
            margin: 15px 0 25px 0;
        }

        .audio-btn {
            background-color: var(--primary);
            color: white;
            border: none;
            width: 85px;
            height: 85px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 2.2rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 20px rgba(230, 57, 70, 0.3);
            transition: all 0.2s ease;
        }

        .audio-btn:hover {
            transform: scale(1.05);
        }

        .hint-text {
            font-size: 0.9rem;
            color: var(--neutral);
            margin-top: 12px;
        }

        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 20px;
        }

        .option-btn {
            background-color: var(--card-bg);
            border: 2px solid #dee2e6;
            padding: 12px;
            border-radius: 8px;
            font-size: 1rem;
            cursor: pointer;
            text-align: center;
            transition: all 0.2s;
            color: var(--text);
        }

        .option-btn:hover:not([disabled]) {
            border-color: var(--secondary);
            background-color: #f8f9fa;
        }

        .option-btn.correct {
            background-color: #e8f5e9;
            border-color: var(--success);
            color: var(--success);
            font-weight: bold;
        }

        .option-btn.incorrect {
            background-color: #ffebee;
            border-color: var(--error);
            color: var(--error);
            opacity: 0.7;
        }

        .option-btn.dont-know {
            grid-column: span 2;
            background-color: #f1f3f5;
            border-style: dashed;
            color: var(--neutral);
        }

        .option-btn.dont-know:hover:not([disabled]) {
            background-color: #e9ecef;
            border-color: var(--neutral);
        }

        .action-btn {
            background-color: var(--text);
            color: white;
            border: none;
            padding: 14px 35px;
            border-radius: 8px;
            font-size: 1.1rem;
            cursor: pointer;
            font-weight: bold;
            transition: opacity 0.2s;
            margin-top: 10px;
            width: 100%;
        }

        .action-btn:hover {
            opacity: 0.9;
        }

        .feedback {
            margin-top: 20px;
            min-height: 90px;
            font-size: 1.1rem;
            line-height: 1.5;
        }

        .reveal-title {
            font-size: 1.6rem;
            color: var(--primary);
            font-weight: bold;
            margin-bottom: 5px;
        }

        .reveal-sub {
            color: var(--neutral);
            font-size: 1.1rem;
            margin-bottom: 15px;
        }

        /* 5-Dot Mastery System Tracker */
        .streak-dots {
            display: flex;
            justify-content: center;
            gap: 6px;
            margin-bottom: 20px;
        }
        
        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background-color: #dee2e6;
            transition: background-color 0.2s;
        }
        
        .dot.active {
            background-color: var(--success);
        }

        .mode-badge {
            display: inline-block;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 4px 10px;
            border-radius: 12px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .mode-main { background-color: #e3f2fd; color: #0d47a1; }
        .mode-review { background-color: #fff3e0; color: #e65100; }
        .mode-dictation { background-color: #e8f5e9; color: #1b5e20; }

        .screen { display: none; }
        .screen.active { display: block; }
    </style>
</head>
<body>

<div class="container">
    
    <div id="quiz-header" style="display: none;">
        <div class="phase-indicator" id="phase-title">Part 1: Listening Comprehension</div>
        <div class="progress-bar"><div class="progress" id="progress-bar-inner"></div></div>
        <div style="display: flex; justify-content: space-between; margin-bottom: 15px; color: #6c757d; font-size: 0.95rem;">
            <span id="progress-text">Words Mastered: 0 / 0</span>
            <span id="queue-count">Remaining: 0</span>
        </div>
    </div>

    <div id="landing-screen" class="screen active">
        <div class="card">
            <h1 style="color: var(--primary); margin-bottom: 10px;">Spanish Audio Trainer</h1>
            <p style="font-size: 1.1rem; line-height: 1.6; color: #6c757d; margin-bottom: 25px;">
                <strong>Part 1:</strong> Identify words by sound. Each word must be answered correctly <strong>5 continuous times</strong> to pass. You have a strict <strong>5-second time limit</strong> per attempt!<br><br>
                <strong>Part 2:</strong> Dictation round covering 20 complete conversational sentences.
            </p>
            <button class="action-btn" style="background-color: var(--primary);" onclick="unlockAndStartApplication()">¡Vamos! Start Practice</button>
        </div>
    </div>

    <div id="game-card" class="screen">
        <div class="timer-bar" id="timer-bar-container"><div class="timer-fill" id="timer-bar-fill"></div></div>
        <div class="card">
            <div id="mode-badge" class="mode-badge mode-main">Main Round</div>
            
            <div class="streak-dots" id="streak-container">
                <div class="dot" id="dot1"></div>
                <div class="dot" id="dot2"></div>
                <div class="dot" id="dot3"></div>
                <div class="dot" id="dot4"></div>
                <div class="dot" id="dot5"></div>
            </div>
            
            <div class="audio-container">
                <button class="audio-btn" onclick="triggerAudioPlayback()" aria-label="Play Spanish audio target">
                    🔊
                </button>
                <div class="hint-text" id="audio-hint-text">Listen carefully to the audio</div>
            </div>

            <div id="mc-options-area" class="options-grid"></div>

            <button id="next-step-btn" class="action-btn" style="display: none; margin: 10px auto 0 auto;" onclick="advanceGameWorkflow()">Next Card →</button>
        </div>

        <div class="feedback" id="feedback-display"></div>
    </div>

    <div id="phase-transition-screen" class="screen">
        <div class="card">
            <h2 id="transition-header">¡Parte 1 Completada! 🎉</h2>
            <p style="font-size: 1.15rem; line-height: 1.6;" id="transition-body">Brilliant focus! You have mastered every unique vocabulary word by passing it 5 continuous times under the time limit. Let's move on to Part 2.</p>
            <button class="action-btn" onclick="beginPartTwoDictationWorkflow()">Start Part 2: 20 Sentences Dictation →</button>
        </div>
    </div>

    <div id="completion-screen" class="screen">
        <div class="card">
            <h2>¡Enhorabuena! 🏆</h2>
            <p style="font-size: 1.2rem; line-height: 1.6;">You have fully completed the training! You mastered all vocabulary under pressure, and safely processed all 20 structural dictation sentences.</p>
            <button class="action-btn" style="background-color: var(--primary);" onclick="restartEntireApplicationState()">Restart Program</button>
        </div>
    </div>

</div>

<script>
    // System Dictionary Matrix
    const dictionary = {
        "el": { meaning: "the (masc.)", ipa: "/el/", sentence: "El café es excelente. (The coffee is excellent.)" },
        "la": { meaning: "the (fem.)", ipa: "/la/", sentence: "La idea es buena. (The idea is good.)" },
        "un": { meaning: "a / an (masc.)", ipa: "/un/", sentence: "Quiero un café. (I want a coffee.)" },
        "una": { meaning: "a / an (fem.)", ipa: "/ˈu.na/", sentence: "Tengo una idea. (I have an idea.)" },
        "de": { meaning: "of / from", ipa: "/de/", sentence: "Es de España. (It is from Spain.)" },
        "que": { meaning: "that / which", ipa: "/ke/", sentence: "Dice que no viene. (Says that he/she is not coming.)" },
        "y": { meaning: "and", ipa: "/i/", sentence: "Café y leche. (Coffee and milk.)" },
        "en": { meaning: "in / on / at", ipa: "/en/", sentence: "Está en la mesa. (It is on the table.)" },
        "no": { meaning: "no / not", ipa: "/no/", sentence: "No quiero café. (I don't want coffee.)" },
        "se": { meaning: "oneself (reflexive)", ipa: "/se/", sentence: "Se lava las manos. (He/She washes his/her hands.)" },
        "ser": { meaning: "to be (essential)", ipa: "/ser/", sentence: "Es de España. (It is from Spain.)" },
        "haber": { meaning: "to have / there is", ipa: "/aˈβer/", sentence: "Hay café aquí. (There is coffee here.)" },
        "café": { meaning: "coffee", ipa: "/kaˈfe/", sentence: "Me gusta el café. (I like coffee.)" },
        "leche": { meaning: "milk", ipa: "/ˈle.tʃe/", sentence: "Quiero leche por favor. (I want milk please.)" },
        "tengo": { meaning: "I have", ipa: "/ˈteŋ.ɡo/", sentence: "Tengo un libro. (I have a book.)" },
        "idea": { meaning: "idea", ipa: "/iˈðe.a/", sentence: "Es una gran idea. (It is a great idea.)" },
        "es": { meaning: "is (from 'ser')", ipa: "/es/", sentence: "Es muy bueno. (It is very good.)" },
        "buena": { meaning: "good (fem.)", ipa: "/ˈbwe.na/", sentence: "Una buena idea. (A good idea.)" },
        "hay": { meaning: "there is / there are", ipa: "/aj/", sentence: "Hay un problema. (There is a problem.)" },
        "gente": { meaning: "people", ipa: "/ˈxen.te/", sentence: "Hay mucha gente. (There are many people.)" },
        "aquí": { meaning: "here", ipa: "/aˈki/", sentence: "Ven aquí. (Come here.)" },
        "dice": { meaning: "he/she says", ipa: "/ˈdi.θe/", sentence: "Él dice la verdad. (He says the truth.)" },
        "venga": { meaning: "he/she comes (subjunctive)", ipa: "/ˈben.ɡa/", sentence: "Espero que venga. (I hope that he/she comes.)" },
        "él": { meaning: "he", ipa: "/el/", sentence: "Él es mi amigo. (He is mi amigo.)" },
        "lava": { meaning: "he/she washes", ipa: "/ˈla.βa/", sentence: "Él se lava. (He washes himself.)" },
        "manos": { meaning: "hands", ipa: "/ˈma.nos/", sentence: "Lava tus manos. (Wash your hands.)" },
        "libro": { meaning: "book", ipa: "/ˈli.βro/", sentence: "Tengo un libro nuevo. (I have a new book.)" },
        "casa": { meaning: "house", ipa: "/ˈka.sa/", sentence: "La casa es grande. (The house is big.)" },
        "amigo": { meaning: "friend", ipa: "/aˈmi.ɣo/", sentence: "Es mi amigo. (He is my friend.)" },
        "bueno": { meaning: "good (masc.)", ipa: "/ˈbwe.no/", sentence: "El café es bueno. (The coffee is good.)" },
        "mesa": { meaning: "table", ipa: "/ˈme.sa/", sentence: "Está en la mesa. (It is on the table.)" }
    };

    // Part 2 Expanded: 20 sentences utilizing core terms systematically
    const dictationSentences = [
        { phrase: "Café y leche.", translation: "Coffee and milk." },
        { phrase: "Tengo una idea que es buena.", translation: "I have an idea that is good." },
        { phrase: "Hay gente aquí.", translation: "There are people here." },
        { phrase: "Es de España, no de Madrid.", translation: "It is from Spain, not from Madrid." },
        { phrase: "Él dice que se lava las manos.", translation: "He says that he washes his hands." },
        { phrase: "El libro es bueno.", translation: "The book is good." },
        { phrase: "No hay leche en la casa.", translation: "There is no milk in the house." },
        { phrase: "Es un buen amigo.", translation: "He is a good friend." },
        { phrase: "Quiero un café y una leche.", translation: "I want a coffee and a milk." },
        { phrase: "Él tiene una casa aquí.", translation: "He has a house here." },
        { phrase: "La mesa es de la casa.", translation: "The table is from the house." },
        { phrase: "No es una buena idea.", translation: "It is not a good idea." },
        { phrase: "Dice que el libro está aquí.", translation: "Says that the book is here." },
        { phrase: "Hay un amigo en la mesa.", translation: "There is a friend at the table." },
        { phrase: "Se lava las manos con leche.", translation: "He/she washes his/her hands with milk." },
        { phrase: "El café de España es bueno.", translation: "The coffee from Spain is good." },
        { phrase: "Tengo un amigo que es de aquí.", translation: "I have a friend who is from here." },
        { phrase: "No, no es mi libro.", translation: "No, it is not my book." },
        { phrase: "Hay una mesa y una casa.", translation: "There is a table and a house." },
        { phrase: "Él dice que no hay café.", translation: "He says that there is no coffee." }
    ];

    let activePool = [];       
    let currentItem = null;    
    let userHasAnswered = false;
    let vocabMasteredCount = 0;
    let totalVocabCount = 0;

    let currentPhase = 1;      
    let dictationIndex = 0;

    // Countdown Timer Properties
    let countdownInterval = null;
    let timeRemainingMs = 5000;
    const totalTimeLimitMs = 5000;

    function cleanToken(rawWord) {
        return rawWord
            .toLowerCase()
            .trim()
            .replace(/[.,\/#!$%\^&\*;:{}=\-_`~()¿?]/g, "")
            .normalize("NFD") 
            .replace(/[\u0300-\u036f]/g, "") 
            .replace(/ñ/g, "n");             
    }

    // Compiles vocab objects into a pool where every item tracks a target streak up to 5
    function buildPartOneVocabularyPool() {
        const uniqueWords = new Set();
        
        dictationSentences.forEach(sentence => {
            const tokens = sentence.phrase.split(/\s+/);
            tokens.forEach(token => {
                const cleaned = cleanToken(token);
                if (cleaned && dictionary[cleaned]) {
                    uniqueWords.add(cleaned);
                }
            });
        });

        // Ensure baseline functional items are fully injected
        ["el", "la", "un", "una", "de", "que", "y", "en", "no", "se", "ser", "haber"].forEach(baseKey => {
            if(dictionary[baseKey]) uniqueWords.add(baseKey);
        });

        activePool = Array.from(uniqueWords).map((wordKey, index) => {
            return {
                id: index,
                word: wordKey,
                meaning: dictionary[wordKey].meaning,
                ipa: dictionary[wordKey].ipa,
                sentence: dictionary[wordKey].sentence,
                streak: 0 // Track continuous passes (0 to 5)
            };
        });

        totalVocabCount = activePool.length;
    }

    function switchScreenView(activeScreenId) {
        document.querySelectorAll('.screen').forEach(el => el.classList.remove('active'));
        document.getElementById(activeScreenId).classList.add('active');
    }

    function unlockAndStartApplication() {
        window.speechSynthesis.speak(new SpeechSynthesisUtterance(""));
        document.getElementById("quiz-header").style.display = "block";
        restartEntireApplicationState();
    }

    function pullConfusableDistractors(correctMeaning, count = 4) {
        const allMeanings = Object.values(dictionary).map(v => v.meaning);
        const filtered = allMeanings.filter(m => m !== correctMeaning);
        return filtered.sort(() => 0.5 - Math.random()).slice(0, count);
    }

    function triggerAudioPlayback() {
        if (!currentItem) return;
        window.speechSynthesis.cancel();

        if (currentPhase === 1) {
            const segments = currentItem.word.split(/\s*[\/\u2014]\s*|\s+ó\s+|\s+o\s+/);
            let cumulativeDelay = 0;
            
            segments.forEach((segment) => {
                const atomicText = segment.trim();
                if (atomicText.length > 0) {
                    setTimeout(() => {
                        const utterance = new SpeechSynthesisUtterance(atomicText);
                        utterance.lang = 'es-ES';
                        utterance.rate = 0.85; 
                        window.speechSynthesis.speak(utterance);
                    }, cumulativeDelay);
                    cumulativeDelay += 900; 
                }
            });
        } else {
            const utterance = new SpeechSynthesisUtterance(currentItem.phrase);
            utterance.lang = 'es-ES';
            utterance.rate = 0.82;
            window.speechSynthesis.speak(utterance);
        }
    }

    // 5-Second Countdown Clock Logic
    function startCountdownTimer() {
        clearInterval(countdownInterval);
        if (currentPhase !== 1) return;

        timeRemainingMs = totalTimeLimitMs;
        document.getElementById("timer-bar-container").style.display = "block";
        const fillBar = document.getElementById("timer-bar-fill");
        fillBar.style.width = "100%";
        fillBar.style.backgroundColor = "var(--primary)";

        const intervalStepMs = 50;
        countdownInterval = setInterval(() => {
            if (userHasAnswered) {
                clearInterval(countdownInterval);
                return;
            }

            timeRemainingMs -= intervalStepMs;
            const percentage = (timeRemainingMs / totalTimeLimitMs) * 100;
            fillBar.style.width = `${percentage}%`;

            if (timeRemainingMs <= 0) {
                clearInterval(countdownInterval);
                handleTimeOutFailure();
            }
        }, intervalStepMs);
    }

    function handleTimeOutFailure() {
        userHasAnswered = true;
        document.getElementById("timer-bar-container").style.display = "none";

        // Highlight correct options automatically
        document.querySelectorAll(".option-btn").forEach(btn => {
            btn.disabled = true;
            if (btn.innerText === currentItem.meaning) btn.classList.add("correct");
        });

        // Reset target element index item streak completely down to 0
        const matchIdx = activePool.findIndex(item => item.id === currentItem.id);
        activePool[matchIdx].streak = 0;

        updateStreakDotsVisuals(0);

        const revealTemplateHTML = `
            <div class="reveal-title">${currentItem.word}</div>
            <div class="reveal-sub">${currentItem.ipa}</div>
        `;

        document.getElementById("feedback-display").innerHTML = `
            ${revealTemplateHTML}
            <strong style="color: var(--error)">Time out! (Over 5 seconds)</strong><br>
            <span style="font-size:0.95rem; color:var(--neutral)">Meaning: <strong>${currentItem.meaning}</strong></span><br>
            <small style="color:#6c757d">Continuous streak reset back to 0.</small>
        `;

        document.getElementById("next-step-btn").style.display = "block";
    }

    function updateStreakDotsVisuals(streakValue) {
        for (let i = 1; i <= 5; i++) {
            const dot = document.getElementById(`dot${i}`);
            if (i <= streakValue) dot.classList.add("active");
            else dot.classList.remove("active");
        }
    }

    function runGlobalInterfacePainter() {
        userHasAnswered = false;
        document.getElementById("feedback-display").innerHTML = "";
        document.getElementById("next-step-btn").style.display = "none";

        const progressBarInner = document.getElementById("progress-bar-inner");
        const progressText = document.getElementById("progress-text");
        const queueCount = document.getElementById("queue-count");
        const badge = document.getElementById("mode-badge");
        const streakContainer = document.getElementById("streak-container");

        if (currentPhase === 1) {
            document.getElementById("phase-title").innerText = "Part 1: Listening Comprehension (5s Limit)";
            document.getElementById("audio-hint-text").innerText = "Listen and quickly pick the meaning before time runs out!";
            document.getElementById("mc-options-area").style.display = "grid";
            
            vocabMasteredCount = activePool.filter(item => item.streak >= 5).length;
            progressBarInner.style.width = `${(vocabMasteredCount / totalVocabCount) * 100}%`;
            progressText.innerText = `Words Mastered: ${vocabMasteredCount} / ${totalVocabCount}`;
            
            const remainingUnmastered = activePool.filter(item => item.streak < 5).length;
            queueCount.innerText = `Active Queue: ${remainingUnmastered}`;

            badge.innerText = "Speed Round";
            badge.className = "mode-badge mode-main";
            streakContainer.style.visibility = "visible";
            
            updateStreakDotsVisuals(currentItem.streak);

            // Generate Options Matrix (4 wrong, 1 correct, 1 "I don't know")
            const options = pullConfusableDistractors(currentItem.meaning, 4);
            options.push(currentItem.meaning);
            options.sort(() => 0.5 - Math.random());
            options.push("I don't know"); 

            const container = document.getElementById("mc-options-area");
            container.innerHTML = "";
            options.forEach(opt => {
                const btn = document.createElement("button");
                btn.className = "option-btn";
                if(opt === "I don't know") btn.classList.add("dont-know");
                btn.innerText = opt;
                btn.onclick = () => evaluateMultipleChoiceSelection(btn, opt);
                container.appendChild(btn);
            });

            startCountdownTimer();

        } else {
            // PART 2: DICTATION - NO KEYBOARD USER INPUT CARD GRAPHICS
            document.getElementById("timer-bar-container").style.display = "none";
            document.getElementById("phase-title").innerText = "Part 2: Phrase Listening Session";
            document.getElementById("audio-hint-text").innerText = "Listen closely to the full sentence structure spoken naturally";
            document.getElementById("mc-options-area").style.display = "none";
            
            badge.innerText = `Sentence ${dictationIndex + 1} of 20`;
            badge.className = "mode-badge mode-dictation";
            streakContainer.style.visibility = "hidden";

            progressBarInner.style.width = `${(dictationIndex / 20) * 100}%`;
            progressText.innerText = `Sentences Completed: ${dictationIndex} / 20`;
            queueCount.innerText = `Remaining Targets: ${20 - dictationIndex}`;

            document.getElementById("next-step-btn").innerText = "Listen Next →";
            document.getElementById("next-step-btn").style.display = "block";
            
            // Instantly display complete transcription logs safely
            document.getElementById("feedback-display").innerHTML = `
                <div class="reveal-title" style="color: var(--secondary)">Spoken Phrase Structure</div>
                <div class="reveal-sub" style="margin-bottom:5px; font-size:1.4rem; color:var(--text)">"${currentItem.phrase}"</div>
                <div style="color: #6c757d; font-size:0.95rem;">Translation: ${currentItem.translation}</div>
            `;
            dictationIndex++;
        }

        setTimeout(triggerAudioPlayback, 400);
    }

    function evaluateMultipleChoiceSelection(clickedBtn, selectedText) {
        if (userHasAnswered) return;
        userHasAnswered = true;
        
        clearInterval(countdownInterval);
        document.getElementById("timer-bar-container").style.display = "none";

        document.querySelectorAll(".option-btn").forEach(btn => btn.disabled = true);
        const feedbackArea = document.getElementById("feedback-display");
        const matchLookupIndex = activePool.findIndex(item => item.id === currentItem.id);

        const revealTemplateHTML = `
            <div class="reveal-title">${currentItem.word}</div>
            <div class="reveal-sub">${currentItem.ipa}</div>
        `;

        if (selectedText === currentItem.meaning) {
            clickedBtn.classList.add("correct");
            activePool[matchLookupIndex].streak += 1;
            
            updateStreakDotsVisuals(activePool[matchLookupIndex].streak);

            if (activePool[matchLookupIndex].streak >= 5) {
                feedbackArea.innerHTML = `
                    ${revealTemplateHTML}
                    <strong style="color: var(--success)">¡Correcto! Streak: 5/5.</strong> Word Mastered completely!<br>
                    <small style="color:#6c757d">${currentItem.sentence}</small>
                `;
            } else {
                feedbackArea.innerHTML = `
                    ${revealTemplateHTML}
                    <strong style="color: var(--success)">¡Correcto!</strong> Streak advanced to ${activePool[matchLookupIndex].streak}/5.<br>
                    <small style="color:#6c757d">${currentItem.sentence}</small>
                `;
            }
        } else {
            clickedBtn.classList.add("incorrect");
            document.querySelectorAll(".option-btn").forEach(btn => {
                if (btn.innerText === currentItem.meaning) btn.classList.add("correct");
            });

            // Hard complete break on failure resets continuous monitoring counter back to 0
            activePool[matchLookupIndex].streak = 0;
            updateStreakDotsVisuals(0);

            let reason = selectedText === "I don't know" ? "Skipped via 'I don't know'." : "Wrong meaning choice.";

            feedbackArea.innerHTML = `
                ${revealTemplateHTML}
                <strong style="color: var(--error)">Incorrect.</strong> ${reason}<br>
                <span style="font-size:0.95rem; color:var(--neutral)">Target Meaning: <strong>${currentItem.meaning}</strong></span><br>
                <small style="color:#6c757d">Continuous progress streak tracking reset back to 0.</small>
            `;
        }

        document.getElementById("next-step-btn").style.display = "block";
    }

    function loadNextPhase1Card() {
        // Find items that haven't hit a consecutive correct streak of 5
        const unmastered = activePool.filter(item => item.streak < 5);
        
        if (unmastered.length > 0) {
            const randIndex = Math.floor(Math.random() * unmastered.length);
            currentItem = unmastered[randIndex];
            runGlobalInterfacePainter();
        } else {
            switchScreenView("phase-transition-screen");
        }
    }

    function beginPartTwoDictationWorkflow() {
        currentPhase = 2;
        dictationIndex = 0;
        document.getElementById("next-step-btn").innerText = "Next Card →";
        switchScreenView("game-card");
        loadNextPhase2Card();
    }

    function loadNextPhase2Card() {
        if (dictationIndex < dictationSentences.length) {
            currentItem = dictationSentences[dictationIndex];
            runGlobalInterfacePainter();
        } else {
            switchScreenView("completion-screen");
            document.getElementById("quiz-header").style.display = "none";
        }
    }

    function advanceGameWorkflow() {
        if (currentPhase === 1) {
            loadNextPhase1Card();
        } else {
            loadNextPhase2Card();
        }
    }

    function restartEntireApplicationState() {
        clearInterval(countdownInterval);
        activePool = [];
        vocabMasteredCount = 0;
        dictationIndex = 0;
        currentPhase = 1;

        buildPartOneVocabularyPool();
        switchScreenView("game-card");
        loadNextPhase1Card();
    }

    document.addEventListener("keydown", function(event) {
        if (event.key === "Enter") {
            const nextBtn = document.getElementById("next-step-btn");
            if (nextBtn.style.display === "block") {
                nextBtn.click();
            }
        }
    });
</script>

</body>
</html>
